{
  "name": "android-calendar-export",
  "version": "0.1.0",
  "description": "Convert meeting data into an \"Add to Google Calendar\" URL for adding events on Android.",
  "type": "module",
  "author": {
    "name": "Dmytro Bilokhonov",
    "email": "entwicklerberg@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwicklerberg/android-calendar-export"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
